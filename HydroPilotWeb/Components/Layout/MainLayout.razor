@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject IJSRuntime JsRuntime

<div class="shell">
    <aside class="shell-sidebar">
        <NavMenu />
    </aside>

    <main class="shell-main">
        <header class="shell-topbar">
            <div class="shell-topbar__titles">
                <h1>@CurrentPage.Title</h1>
                <p>@CurrentPage.Subtitle</p>
            </div>

            <div class="shell-topbar__actions">
                <div class="status-pill"><span></span> Sistemas estables</div>

                <NavLink class="topbar-action" href="settings/notifications" aria-label="Notificaciones">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M15 17h5l-1.4-1.4A2 2 0 0 1 18 14.2V11a6 6 0 0 0-4-5.7V4a2 2 0 0 0-4 0v1.3A6 6 0 0 0 6 11v3.2c0 .5-.2 1-.6 1.4L4 17h5" />
                        <path d="M9.5 17a2.5 2.5 0 0 0 5 0" />
                    </svg>
                </NavLink>

                <NavLink class="topbar-action" href="settings/profile" aria-label="Configuración">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <circle cx="12" cy="12" r="3.2" />
                        <path d="M19.4 15a1.7 1.7 0 0 0 .3 1.8l.1.1a2 2 0 0 1-1.4 3.4 2.7 2.7 0 0 1-1-.2l-.2-.1a1.7 1.7 0 0 0-1.6.2l-.1.1a2 2 0 0 1-3.2-.8l0-.2a1.7 1.7 0 0 0-1.2-1.2l-.2 0a2 2 0 0 1-.8-3.2l.1-.1a1.7 1.7 0 0 0 .2-1.6l-.1-.2a2 2 0 0 1 .8-3.2h.2a1.7 1.7 0 0 0 1.2-1.2l0-.2a2 2 0 0 1 3.2-.8l.1.1c.4.4 1 .6 1.6.2l.2-.1a2 2 0 0 1 2.9 1.9 2.7 2.7 0 0 1-.2 1l-.1.2a1.7 1.7 0 0 0 .2 1.6l.1.1a2 2 0 0 1-.8 3.2l-.2 0a1.7 1.7 0 0 0-1.2 1.2z" />
                    </svg>
                </NavLink>

                <button class="topbar-action" @onclick="ToggleTheme" aria-label="Alternar tema">
                    @if (_isDark)
                    {
                        <svg viewBox="0 0 24 24">
                            <circle cx="12" cy="12" r="5"/>
                            <line x1="12" y1="1" x2="12" y2="3"/>
                            <line x1="12" y1="21" x2="12" y2="23"/>
                            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
                            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                            <line x1="1" y1="12" x2="3" y2="12"/>
                            <line x1="21" y1="12" x2="23" y2="12"/>
                            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
                            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
                        </svg>
                    }
                    else
                    {
                        <svg viewBox="0 0 24 24">
                            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                        </svg>
                    }
                </button>
            </div>
        </header>

        <section class="shell-content">
            @Body
        </section>
    </main>
</div>

@code {
    private PageHeader CurrentPage => ResolvePage(Navigation.ToBaseRelativePath(Navigation.Uri));

    private static PageHeader ResolvePage(string relativePath)
    {
        var path = relativePath.Trim('/').ToLowerInvariant();

        return path switch
        {
            "" => new PageHeader("Vista General del Sistema", "Invernadero Alpha-01 · Lechuga hidropónica NFT"),
            "reports" => new PageHeader("Informes", "Histórico de producción, consumo y reportes exportables."),
            "forecasting" => new PageHeader("Módulo de Forecasting", "Predicción de variables clave del cultivo para los próximos 14 días."),
            "simulation" => new PageHeader("Módulo de Simulación", "Probá escenarios what-if y observá el impacto estimado en la cosecha."),
            "optimization" => new PageHeader("Módulo de Optimización", "Recomendaciones basadas en IA para mejorar rendimiento y reducir costos."),
            "anomalies" => new PageHeader("Módulo de Anomalías", "Detección automática de eventos fuera de rango y desvíos de comportamiento."),
            "settings/profile" => new PageHeader("Configuración de usuario", "Datos personales, idioma y seguridad de tu cuenta."),
            "settings/notifications" => new PageHeader("Configuración de notificaciones", "Definí cómo y cuándo querés recibir avisos del sistema."),
            "db-test" => new PageHeader("Prueba de conexión a la base de datos", "Verificá el acceso al motor y el estado de los sensores de prueba."),
            "counter" => new PageHeader("Counter", "Demo de interacción."),
            "weather" => new PageHeader("Weather", "Demo de datos de ejemplo."),
            _ => new PageHeader("HydroPilot", "Vista operativa"),
        };
    }

    private sealed record PageHeader(string Title, string Subtitle);

    private bool _isDark = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var isDark = await JsRuntime.InvokeAsync<bool>("eval", "document.documentElement.dataset.theme === 'dark'");
            if (_isDark != isDark)
            {
                _isDark = isDark;
                StateHasChanged();
            }
        }
    }

    private async Task ToggleTheme()
    {
        _isDark = !_isDark;
        await JsRuntime.InvokeVoidAsync("theme.toggle");
    }
}

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
