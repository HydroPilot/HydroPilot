@using System.Security.Claims

<div class="brand-block">
    <a class="brand" href="/">
        <img class="brand__logo" src="assets/hydropilot-white.png" alt="HydroPilot" />
        <span class="brand__text">
            <strong>HydroPilot</strong>
            <small>Vista operativa</small>
        </span>
    </a>
</div>

<nav class="sidebar-nav" aria-label="Navegación principal">
    <div class="sidebar-nav__section">
        <span class="sidebar-nav__label">Monitoreo</span>

        <NavLink class="sidebar-nav__item" href="" Match="NavLinkMatch.All">
            <span>⌂</span>
            <span>Dashboard</span>
        </NavLink>

        <NavLink class="sidebar-nav__item" href="reports">
            <span>▦</span>
            <span>Informes</span>
        </NavLink>

        <NavLink class="sidebar-nav__item" href="forecasting">
            <span>↗</span>
            <span>Forecasting</span>
        </NavLink>

        <NavLink class="sidebar-nav__item" href="simulation">
            <span>⚗</span>
            <span>Simulación</span>
        </NavLink>

        <NavLink class="sidebar-nav__item" href="optimization">
            <span>✧</span>
            <span>Optimización</span>
        </NavLink>

        <NavLink class="sidebar-nav__item" href="anomalies">
            <span>⚠</span>
            <span>Anomalías</span>
        </NavLink>
    </div>

    <div class="sidebar-nav__section">
        <span class="sidebar-nav__label">Ajustes</span>

        <NavLink class="sidebar-nav__item" href="settings/profile">
            <span>◉</span>
            <span>Perfil</span>
        </NavLink>

        <NavLink class="sidebar-nav__item" href="settings/notifications">
            <span>◍</span>
            <span>Notificaciones</span>
        </NavLink>

        <NavLink class="sidebar-nav__item" href="db-test">
            <span>◈</span>
            <span>DB Test</span>
        </NavLink>

        <AuthorizeView>
            <Authorized>
                @if (context.User.IsInRole("Administrador"))
                {
                    <NavLink class="sidebar-nav__item" href="admin/users">
                        <span>▣</span>
                        <span>Usuarios</span>
                    </NavLink>
                }
            </Authorized>
        </AuthorizeView>
    </div>
</nav>

<div class="sidebar-footer">
    <AuthorizeView>
        <Authorized>
            <div class="user-chip">
                <span class="user-chip__avatar">@GetInitials(context.User)</span>
                <div>
                    <strong>@GetDisplayName(context.User)</strong>
                    <small>@GetRole(context.User)</small>
                </div>
            </div>
            <div class="logout-wrap">
                <a class="logout-btn" href="/logout">Cerrar sesión</a>
            </div>
        </Authorized>
    </AuthorizeView>
</div>

<style>
    .logout-wrap {
        margin-top: 10px;
        text-align: center;
    }
    .logout-btn {
        font-size: 12px;
        color: #70869a;
        text-decoration: none;
        transition: color 0.15s;
    }
    .logout-btn:hover {
        color: #e05252;
    }
</style>

@code {
    private static string GetInitials(System.Security.Claims.ClaimsPrincipal user)
    {
        var given = user.FindFirst("http://schemas.xmlsoap.org/ws/2005/05/identity/claims/givenname")?.Value
                    ?? user.FindFirst(ClaimTypes.GivenName)?.Value;
        var surname = user.FindFirst("http://schemas.xmlsoap.org/ws/2005/05/identity/claims/surname")?.Value
                      ?? user.FindFirst(ClaimTypes.Surname)?.Value;
        var name = user.Identity?.Name;

        if (!string.IsNullOrWhiteSpace(given) && !string.IsNullOrWhiteSpace(surname))
            return $"{given[0]}{surname[0]}".ToUpperInvariant();

        if (!string.IsNullOrWhiteSpace(name) && name.Length >= 2)
            return $"{name[0]}{name[1]}".ToUpperInvariant();

        return "??";
    }

    private static string GetDisplayName(System.Security.Claims.ClaimsPrincipal user)
    {
        var given = user.FindFirst("http://schemas.xmlsoap.org/ws/2005/05/identity/claims/givenname")?.Value
                    ?? user.FindFirst(ClaimTypes.GivenName)?.Value ?? "";
        var surname = user.FindFirst("http://schemas.xmlsoap.org/ws/2005/05/identity/claims/surname")?.Value
                      ?? user.FindFirst(ClaimTypes.Surname)?.Value ?? "";

        if (!string.IsNullOrWhiteSpace(given) || !string.IsNullOrWhiteSpace(surname))
            return $"{given} {surname}".Trim();

        return user.Identity?.Name ?? "Usuario";
    }

    private static string GetRole(System.Security.Claims.ClaimsPrincipal user)
    {
        return user.FindFirst(ClaimTypes.Role)?.Value ?? "Operador";
    }
}

