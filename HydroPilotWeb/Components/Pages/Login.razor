@page "/login"
@layout Layout.LoginLayout
@inject NavigationManager Navigation

<PageTitle>Iniciar sesión - HydroPilot</PageTitle>

<div class="login-page">
    <div class="login-card">
        <div class="login-card__brand">
            <img class="login-card__logo" src="assets/hydropilot-white.png" alt="HydroPilot" />
            <h1>HydroPilot</h1>
            <p>Monitoreo inteligente de cultivos hidropónicos</p>
        </div>

        <a href="/login-google" class="btn-google">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
            Iniciar sesión con Google
        </a>
        
        <div class="login-card__divider"></div>

        <form method="post" action="/login-admin" class="admin-form">
            <label class="field-block"><span>Admin</span><input type="password" name="password" placeholder="••••••••" /></label>
            <p class="admin-form__error">@ErrorUi</p>
            <button type="submit" class="btn-admin">Acceso admin</button>
        </form>


    </div>
</div>

<style>
    .login-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #0f1923 0%, #1a2f3a 100%);
    }

    .login-card {
    background: #162231;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    padding: 48px 40px;
    width: 100%;
    max-width: 400px;
    text-align: center;
    }

    .login-card__brand {
    margin-bottom: 32px;
    }

    .login-card__logo {
    width: 64px;
    height: 64px;
    border-radius: 14px;
    margin-bottom: 16px;
    }

    .login-card h1 {
    font-size: 24px;
    font-weight: 700;
    color: #e4ecf6;
    margin: 0 0 8px;
    }

    .login-card p {
    color: #70869a;
    font-size: 14px;
    margin: 0;
    }

    .btn-google {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: #ffffff;
    color: #1f1f1f;
    font-weight: 600;
    font-size: 15px;
    padding: 12px 28px;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.15s, box-shadow 0.15s;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
    }

    .btn-google:hover {
    background: #f2f2f2;
    box-shadow: 0 4px 14px rgba(0,0,0,0.25);
    }

    .login-card__divider {
    margin: 24px 0 20px;
    border-top: 1px solid rgba(255,255,255,0.08);
    text-align: center;
    position: relative;
    }

    .login-card__divider span {
    position: relative;
    top: -10px;
    background: #162231;
    padding: 0 12px;
    font-size: 11px;
    color: #475d70;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    }

    .admin-form {
    text-align: left;
    }

    .admin-form .field-block {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-bottom: 14px;
    }

    .admin-form .field-block span {
    font-size: 13px;
    color: #70869a;
    font-weight: 500;
    }

    .admin-form .field-block input {
    background: #0f1923;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 6px;
    padding: 10px 12px;
    color: #e4ecf6;
    font-size: 14px;
    outline: none;
    transition: border-color 0.15s;
    }

    .admin-form .field-block input:focus {
    border-color: #00d4aa;
    }

    .admin-form__error {
    color: #e05252;
    font-size: 12px;
    margin: 0 0 8px;
    }

    .btn-admin {
    width: 100%;
    background: transparent;
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 8px;
    padding: 10px 20px;
    color: #70869a;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
    }

    .btn-admin:hover {
    background: rgba(255,255,255,0.05);
    color: #e4ecf6;
    border-color: rgba(255,255,255,0.2);
    }

    .login-card__hint {
    margin-top: 20px;
    font-size: 12px;
    color: #475d70;
    }
</style>

@code {
    [SupplyParameterFromQuery]
    private string? Error { get; set; }

    private string ErrorUi => Error switch
    {
        "password_required" => "Contraseña requerida.",
        "invalid_password" => "Contraseña incorrecta.",
        _ => ""
    };
}
