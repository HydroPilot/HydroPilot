@page "/admin/users"
@attribute [Authorize(Policy = "RequireAdministrador")]
@using HydroPilotWeb.Models
@using HydroPilotWeb.Services
@using System.Security.Claims
@inject UserService UserService
@inject AuthenticationStateProvider AuthState

<div class="users-page">
<PageTitle>Gestión de usuarios - HydroPilot</PageTitle>

<div class="page-header">
    <h2>Gestión de usuarios</h2>
    <p>Administración de roles y permisos</p>
</div>

<div class="panel">
    <table class="users-table">
        <thead>
            <tr>
                <th>Usuario</th>
                <th>Email</th>
                <th>Proveedor</th>
                <th>Rol</th>
                <th>Ultimo acceso</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in _users)
            {
                var isSelf = user.Id == _currentUserId;
                <tr>
                    <td>
                        <div class="user-cell">
                            <span class="user-cell__avatar">@GetInitials(user)</span>
                            <span>@GetDisplayName(user)</span>
                        </div>
                    </td>
                    <td>@user.Email</td>
                    <td>@(user.PasswordHash != null ? "Local" : "Google")</td>
                    <td>
                        @if (isSelf)
                        {
                            <span class="role-text">Administrador</span>
                        }
                        else
                        {
                            <select class="role-select" value="@user.Role"
                                    @onchange="e => OnRoleChanged(user.Id, e.Value?.ToString() ?? user.Role)">
                                <option value="no-asignado">Sin rol (no-asignado)</option>
                                <option value="Operador">Operador</option>
                                <option value="Productor">Productor</option>
                                <option value="Soporte Técnico">Soporte Técnico</option>
                            </select>
                        }
                    </td>
                    <td>@user.LastLoginAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        @if (!isSelf && user.PasswordHash == null)
                        {
                            @if (_deletingUserId == user.Id)
                            {
                                <span class="inline-delete">
                                    <span class="inline-delete__label">Eliminar?</span>
                                    <button type="button" class="inline-delete__btn inline-delete__btn--no"
                                            @onclick="() => _deletingUserId = null">✕</button>
                                    <button type="button" class="inline-delete__btn inline-delete__btn--yes"
                                            @onclick="() => ConfirmDelete(user.Id)">✓</button>
                                </span>
                            }
                            else
                            {
                                <button type="button" class="btn-delete" @onclick="() => _deletingUserId = user.Id"
                                        title="Eliminar usuario">
                                    🗑
                                </button>
                            }
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (_roleChanges.Count > 0)
    {
        <div class="save-bar">
            <span class="save-bar__hint">@_roleChanges.Count cambio(s) sin guardar</span>
            <button class="btn-pill btn-pill--solid" @onclick="SaveChanges">Guardar cambios</button>
        </div>
    }
</div>
</div>

<style>
    .page-header {
        margin-bottom: 24px;
    }

    .page-header h2 {
        font-size: 22px;
        font-weight: 700;
        color: var(--text-primary);
        margin: 0 0 4px;
    }

    .page-header p {
        color: var(--text-muted);
        font-size: 14px;
        margin: 0;
    }

    .panel {
        background: var(--bg-panel);
        border: 1px solid var(--border-panel);
        border-radius: 14px;
        padding: 22px;
    }

    .users-table {
        width: 100%;
        border-collapse: collapse;
    }

    .users-table th {
        text-align: left;
        font-size: 12px;
        font-weight: 600;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding: 12px 16px;
        border-bottom: 1px solid var(--border-panel);
    }

    .users-table td {
        padding: 12px 16px;
        border-bottom: 1px solid var(--border-row);
        font-size: 14px;
        color: var(--text-primary);
    }

    .users-table tr:hover td {
        background: var(--row-hover);
    }

    .user-cell {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .user-cell__avatar {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        background: var(--accent-glow);
        border-radius: 8px;
        font-size: 12px;
        font-weight: 600;
        color: var(--accent);
        flex-shrink: 0;
    }

    .role-text {
        font-size: 14px;
        color: var(--text-muted);
        font-style: italic;
    }

    .role-select {
        background: var(--bg-input);
        border: 1px solid var(--border-input);
        border-radius: 6px;
        padding: 6px 10px;
        color: var(--text-primary);
        font-size: 13px;
        outline: none;
        cursor: pointer;
    }

    .role-select option {
        background: var(--bg-panel);
        color: var(--text-primary);
    }

    .role-select:focus {
        border-color: var(--accent);
    }

    .save-bar {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 16px;
        margin-top: 16px;
        padding: 14px 16px;
        border-top: 1px solid var(--border-panel);
    }

    .save-bar__hint {
        font-size: 13px;
        color: var(--text-muted);
    }

    .btn-delete {
        background: transparent;
        border: 1px solid var(--border-input);
        border-radius: 6px;
        padding: 6px 10px;
        cursor: pointer;
        opacity: 0.4;
        transition: opacity 0.15s, background 0.15s;
        font-size: 14px;
    }

    .btn-delete:hover {
        opacity: 1;
        background: rgba(239,68,68,0.12);
        border-color: rgba(239,68,68,0.4);
    }

    .inline-delete {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        white-space: nowrap;
    }

    .inline-delete__label {
        font-size: 13px;
        color: var(--text-muted);
    }

    .inline-delete__btn {
        width: 28px;
        height: 28px;
        border-radius: 6px;
        border: 1px solid transparent;
        font-size: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background 0.15s;
        padding: 0;
    }

    .inline-delete__btn--no {
        background: var(--chip-bg);
        color: var(--text-muted);
        border-color: var(--border-panel);
    }

    .inline-delete__btn--no:hover {
        background: var(--accent-glow);
        color: var(--text-secondary);
    }

    .inline-delete__btn--yes {
        background: rgba(239,68,68,0.15);
        color: #f87171;
    }

    .inline-delete__btn--yes:hover {
        background: rgba(239,68,68,0.25);
    }
</style>

@code {
    private List<User> _users = new();
    private Dictionary<int, string> _roleChanges = new();
    private int _currentUserId;
    private int? _deletingUserId;

    protected override async Task OnInitializedAsync()
    {
        _users = await UserService.GetAllUsersAsync();

        var authState = await AuthState.GetAuthenticationStateAsync();
        var userIdClaim = authState.User.FindFirst("user_id")?.Value;
        _currentUserId = userIdClaim != null ? int.Parse(userIdClaim) : -1;
    }

    private void OnRoleChanged(int userId, string newRole)
    {
        var user = _users.First(u => u.Id == userId);
        if (newRole == user.Role)
        {
            _roleChanges.Remove(userId);
        }
        else
        {
            _roleChanges[userId] = newRole;
        }
    }

    private async Task SaveChanges()
    {
        foreach (var (userId, newRole) in _roleChanges)
        {
            await UserService.UpdateRoleAsync(userId, newRole);
            var user = _users.First(u => u.Id == userId);
            user.Role = newRole;
        }

        _roleChanges.Clear();
    }

    private async Task ConfirmDelete(int userId)
    {
        var success = await UserService.DeleteUserAsync(userId);
        if (success)
        {
            var user = _users.First(u => u.Id == userId);
            _users.Remove(user);
            _roleChanges.Remove(userId);
        }
        _deletingUserId = null;
    }

    private static string GetInitials(User user)
    {
        if (!string.IsNullOrWhiteSpace(user.GivenName) || !string.IsNullOrWhiteSpace(user.Surname))
            return $"{(string.IsNullOrWhiteSpace(user.GivenName) ? "" : user.GivenName[0].ToString())}{(string.IsNullOrWhiteSpace(user.Surname) ? "" : user.Surname[0].ToString())}".ToUpperInvariant();

        return user.Email.Length >= 2 ? user.Email[..2].ToUpperInvariant() : "??";
    }

    private static string GetDisplayName(User user)
    {
        if (!string.IsNullOrWhiteSpace(user.GivenName) || !string.IsNullOrWhiteSpace(user.Surname))
            return $"{user.GivenName} {user.Surname}".Trim();

        return user.Email;
    }
}
